<Window x:Class="JunkCleaner.Updater.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Обновление JunkCleaner"
        Height="220"
        Width="560"
        MinHeight="200"
        MinWidth="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Text="Обновление JunkCleaner" />

        <TextBlock x:Name="StatusText"
                   Grid.Row="1"
                   Margin="0,12,0,8"
                   TextWrapping="Wrap"
                   Text="Подготовка обновления…" />

        <ProgressBar x:Name="Progress"
                     Grid.Row="2"
                     Height="18"
                     Minimum="0"
                     Maximum="100"
                     VerticalAlignment="Top" />

        <TextBlock x:Name="DetailsText"
                   Grid.Row="3"
                   Margin="0,10,0,0"
                   Foreground="#666"
                   TextWrapping="Wrap"
                   FontSize="12" />
    </Grid>
</Window>
