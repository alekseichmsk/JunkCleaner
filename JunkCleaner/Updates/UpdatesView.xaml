<UserControl x:Class="JunkCleaner.Updates.UpdatesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="360">
  <Grid Margin="0,8,0,0">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Margin="0,0,0,12">
      <TextBlock Text="Автообновление через GitHub Releases"
                 FontWeight="SemiBold"
                 Foreground="{DynamicResource Brush.TextBright}" />
      <TextBlock x:Name="RepositoryText"
                 Margin="0,4,0,0"
                 TextWrapping="Wrap"
                 Foreground="{DynamicResource Brush.TextMuted}" />
      <TextBlock x:Name="StatusText"
                 Margin="0,8,0,0"
                 TextWrapping="Wrap"
                 Foreground="{DynamicResource Brush.TextMuted}" />
      <TextBlock x:Name="AssetText"
                 Margin="0,4,0,0"
                 TextWrapping="Wrap"
                 FontWeight="SemiBold"
                 Foreground="{DynamicResource Brush.AccentMist}" />

      <ProgressBar x:Name="Progress"
                   Height="5"
                   Margin="0,10,0,0"
                   Minimum="0"
                   Maximum="100"
                   Visibility="Collapsed" />

      <WrapPanel Margin="0,12,0,0">
        <Button x:Name="CheckButton"
                MinWidth="150"
                Margin="0,0,10,8"
                Content="Проверить обновления"
                Click="Check_Click" />
        <Button x:Name="DownloadButton"
                MinWidth="170"
                Margin="0,0,10,8"
                Content="Скачать и обновить"
                IsEnabled="False"
                Click="Download_Click" />
        <Button x:Name="ReleasePageButton"
                MinWidth="150"
                Margin="0,0,10,8"
                Content="Открыть релиз"
                IsEnabled="False"
                Click="ReleasePage_Click" />
        <Button x:Name="CancelButton"
                MinWidth="90"
                Margin="0,0,10,8"
                Content="Отмена"
                IsEnabled="False"
                Click="Cancel_Click" />
      </WrapPanel>
    </StackPanel>

    <TextBox x:Name="ReleaseNotesBox"
             Grid.Row="1"
             AcceptsReturn="True"
             TextWrapping="Wrap"
             VerticalScrollBarVisibility="Auto"
             HorizontalScrollBarVisibility="Auto"
             FontFamily="Consolas"
             Background="{DynamicResource Brush.BackgroundMid}"
             Foreground="{DynamicResource Brush.TextBright}"
             BorderBrush="{DynamicResource Brush.Border}"
             IsReadOnly="True"
             Text="Здесь появятся заметки релиза после проверки." />
  </Grid>
</UserControl>
