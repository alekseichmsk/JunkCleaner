<Window x:Class="JunkCleaner.CleanupPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="☠ Предпросмотр очистки"
        Height="560"
        Width="720"
        MinHeight="320"
        MinWidth="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
  <DockPanel Margin="16">
    <StackPanel DockPanel.Dock="Bottom"
                Margin="0,12,0,0"
                Orientation="Horizontal"
                HorizontalAlignment="Right">
      <Button Width="120"
              Height="28"
              Margin="0,0,10,0"
              Content="Отмена"
              IsCancel="True"
              Click="Cancel_Click" />
      <Button Width="150"
              Height="28"
              Content="Удалить"
              IsDefault="True"
              Click="Delete_Click" />
    </StackPanel>

    <TextBox x:Name="PreviewBody"
             AcceptsReturn="True"
             TextWrapping="NoWrap"
             VerticalScrollBarVisibility="Auto"
             HorizontalScrollBarVisibility="Auto"
             FontFamily="Consolas"
             Background="{DynamicResource Brush.BackgroundMid}"
             Foreground="{DynamicResource Brush.TextBright}"
             BorderBrush="{DynamicResource Brush.Border}"
             CaretBrush="{DynamicResource Brush.TextMuted}"
             SelectionBrush="{DynamicResource Brush.AccentMist}"
             IsReadOnly="True"
             IsReadOnlyCaretVisible="False" />
  </DockPanel>
</Window>
