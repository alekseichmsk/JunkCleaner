<Window x:Class="JunkCleaner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:large="clr-namespace:JunkCleaner.LargeFiles"
        xmlns:leftovers="clr-namespace:JunkCleaner.ProgramLeftovers"
        xmlns:updates="clr-namespace:JunkCleaner.Updates"
        Title="☠ JunkCleaner — тихая чистка"
        Width="720"
        Height="640"
        MinWidth="540"
        MinHeight="520"
        WindowStartupLocation="CenterScreen">
  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />
  </Window.Resources>
  <DockPanel Margin="16">
    <Border DockPanel.Dock="Top"
            Margin="0,0,0,10"
            Padding="12,8"
            CornerRadius="4"
            Background="{DynamicResource Brush.BackgroundMid}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Orientation="Vertical">
          <StackPanel Orientation="Horizontal">
            <TextBlock FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.AccentMist}"
                       Text="☠" />
            <TextBlock Margin="8,0,0,0"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.TextBright}"
                       Text="JunkCleaner" />
            <TextBlock Margin="10,4,0,0"
                       FontSize="11"
                       Foreground="{DynamicResource Brush.TextMuted}"
                       Text="✦ ритуал освобождения диска ✦" />
          </StackPanel>
          <TextBlock Margin="0,4,0,0"
                     FontSize="11"
                     Foreground="{DynamicResource Brush.TextMuted}"
                     TextWrapping="Wrap"
                     Opacity="0.9"
                     Text="Старые времена шептали: что уходит в пыль — не возвращается без цены. Отмечайте категории с осторожностью." />
        </StackPanel>
        <Viewbox Grid.Column="1"
                 Width="56"
                 Height="56"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Center"
                 Opacity="0.22">
          <Canvas Width="100" Height="100">
            <!-- Упрощённый силуэт черепа (декор) -->
            <Ellipse Canvas.Left="22" Canvas.Top="18" Width="22" Height="24" Fill="{DynamicResource Brush.AccentRose}" />
            <Ellipse Canvas.Left="56" Canvas.Top="18" Width="22" Height="24" Fill="{DynamicResource Brush.AccentRose}" />
            <Path Fill="{DynamicResource Brush.TextMuted}"
                  Data="M 20 52 Q 50 42 80 52 L 78 72 Q 50 88 22 72 Z" />
            <Rectangle Canvas.Left="34" Canvas.Top="60" Width="8" Height="14" Fill="{DynamicResource Brush.BackgroundDeep}" RadiusX="2" RadiusY="2" />
            <Rectangle Canvas.Left="46" Canvas.Top="62" Width="8" Height="12" Fill="{DynamicResource Brush.BackgroundDeep}" RadiusX="2" RadiusY="2" />
            <Rectangle Canvas.Left="58" Canvas.Top="60" Width="8" Height="14" Fill="{DynamicResource Brush.BackgroundDeep}" RadiusX="2" RadiusY="2" />
          </Canvas>
        </Viewbox>
      </Grid>
    </Border>
    <TabControl Margin="0,8,0,0">
      <TabItem Header="Очистка">
        <DockPanel>
          <!-- Menu/MenuItem даёт светлый фон подменю на части систем; здесь — обычная кнопка из темы -->
          <StackPanel DockPanel.Dock="Top"
                      Margin="0,0,0,8"
                      Orientation="Horizontal">
            <TextBlock VerticalAlignment="Center"
                       Margin="0,0,12,0"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.TextMuted}"
                       Text="Сервис" />
            <Button MinWidth="220"
                    HorizontalAlignment="Left"
                    Click="Duplicates_Click"
                    Content="Поиск дубликатов файлов…" />
          </StackPanel>
          <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
            <Separator Margin="0,0,0,12" />
            <StackPanel Orientation="Horizontal"
                        Margin="0,0,0,10"
                        VerticalAlignment="Center">
              <TextBlock VerticalAlignment="Center"
                         Foreground="{DynamicResource Brush.TextMuted}"
                         Text="Безопасность: не трогать файлы младше" />
              <TextBox x:Name="MinAgeDaysBox"
                       Width="54"
                       Margin="8,0,8,0"
                       Text="1"
                       TextAlignment="Right"
                       ToolTip="0 = без фильтра по возрасту" />
              <TextBlock VerticalAlignment="Center"
                         Foreground="{DynamicResource Brush.TextMuted}"
                         Text="дней (0 = без фильтра)" />
            </StackPanel>
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <Button x:Name="ScanButton"
                      Grid.Row="0"
                      Grid.Column="0"
                      Content="Сканировать"
                      Height="28"
                      MinWidth="112"
                      Margin="0,0,6,8"
                      HorizontalAlignment="Stretch"
                      Click="Scan_Click" />
              <Button x:Name="CleanButton"
                      Grid.Row="0"
                      Grid.Column="1"
                      Content="Очистить выбранное"
                      Height="28"
                      MinWidth="148"
                      Margin="3,0,3,8"
                      HorizontalAlignment="Stretch"
                      Click="Clean_Click" />
              <Button x:Name="CancelButton"
                      Grid.Row="0"
                      Grid.Column="2"
                      Content="Отмена"
                      Height="28"
                      MinWidth="88"
                      Margin="6,0,0,8"
                      HorizontalAlignment="Stretch"
                      Click="Cancel_Click"
                      IsEnabled="False" />
              <Button x:Name="DnsButton"
                      Grid.Row="1"
                      Grid.Column="0"
                      Grid.ColumnSpan="3"
                      Content="Сбросить DNS‑кэш (ipconfig /flushdns)"
                      Height="28"
                      MinHeight="28"
                      HorizontalAlignment="Stretch"
                      Click="DnsFlush_Click" />
            </Grid>
            <TextBlock x:Name="HintDns"
                       Margin="0,8,0,0"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource Brush.BorderMuted}"
                       FontSize="11"
                       Text="Для некоторых политик сети может потребоваться запуск приложения или консоли с правами администратора." />
          </StackPanel>

          <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,0,0,16">
              <ProgressBar x:Name="Progress"
                           Height="6"
                           IsIndeterminate="True"
                           Margin="0,0,0,8"
                           Visibility="Collapsed" />
              <TextBlock x:Name="StatusText"
                         TextWrapping="Wrap"
                         Text="Выберите категории и нажмите «Сканировать»."
                         Margin="0,0,0,12" />

              <TextBlock Text="Категории" FontWeight="SemiBold" Margin="0,0,0,8" />

              <ListBox x:Name="CategoryList"
                       BorderThickness="1"
                       ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                       Padding="8">
                <ListBox.ItemContainerStyle>
                  <Style BasedOn="{StaticResource {x:Type ListBoxItem}}" TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                  </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <Grid Margin="0,6">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <CheckBox Grid.Column="0"
                                VerticalAlignment="Top"
                                Margin="0,2,12,0"
                                IsChecked="{Binding IsIncluded, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                      <StackPanel Grid.Column="1">
                        <StackPanel Orientation="Horizontal">
                          <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                          <TextBlock Text="нужен админ"
                                     Margin="8,0,0,0"
                                     Foreground="{DynamicResource Brush.AccentMist}"
                                     FontSize="11"
                                     VerticalAlignment="Center"
                                     Visibility="{Binding RequiresAdmin, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                        <TextBlock Text="{Binding DescriptionText}"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource Brush.TextMuted}"
                                   FontSize="11"
                                   Margin="0,2,0,0" />
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                          <TextBlock Text="Найдено:" FontWeight="Normal" VerticalAlignment="Center" />
                          <TextBlock Margin="8,0,0,0"
                                     Text="{Binding SizeText}"
                                     VerticalAlignment="Center"
                                     FontWeight="SemiBold" />
                        </StackPanel>
                      </StackPanel>
                    </Grid>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </StackPanel>
          </ScrollViewer>
        </DockPanel>
      </TabItem>
      <TabItem Header="Крупные файлы">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <large:LargeFilesView Margin="2,8,2,16" />
        </ScrollViewer>
      </TabItem>
      <TabItem Header="Остатки программ">
        <leftovers:ProgramLeftoversView Margin="2,8,2,16" />
      </TabItem>
      <TabItem Header="Обновления">
        <updates:UpdatesView Margin="2,8,2,16" />
      </TabItem>
    </TabControl>
  </DockPanel>
</Window>
